  Application("DB_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Private/Database"
  Application("LOGS_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Private/Database/Logs"
  Application("TEMP_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Private/Database/Temp"
  Application("SKINS_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Private/Skins"
  Application("IMAGES_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Public/Images"
  Application("UPLOAD_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Public/Uploads"
  Application("HTML_PATH") = Application("WINBOARD_PHYSICAL_PATH") & "/Public/HTML"
  Application("COOKIE_PATH") = ""
  Application("DB_TYPE") = "dbm"
  Application("DB_HOST") = ""
  Application("DB_NAME") = ""
  Application("DB_USERNAME")= ""
  Application("DB_PASSWORD")= ""
  Application("FLOCK") = "0"
  Application("EXTENSTION") = "PL"
  Application("SSI") = "0"
  Application("TOPIC_EXTENSTION") = "cgi"
  Application("TIMEZONE") = "GMT +8"
  Application("LOCALTIME_OFFSET") = 0
  Application("DATE_FORMAT") = "EU"
  Application("TIME_FORMAT") = 24
  Application("SENDMAIL") = ""
  Application("MAIL_SYSTEM") = ""
  Application("SMTP_PATH") = ""
  Application("SENDMAIL_PATH") = ""
  Application("SKIN") = "Default"
  Application("STATS") = ""
  Application("LOGS") = ""
  Application("ONLINE") = 1
  Application("SESSIONS_EXPIRE") = 86400
  Application("OFFLINE_MESSAGE") = "ąďĄÜ°_ˇAŻ¸ŞřĄż¦b­×˛z°Q˝×Ş©ˇA˝Đżđ¤@ÂI¦A¤W¨Ó¬Ý¬ÝˇA¦hÁÂ¦X§@ˇI"
  Application("IP_FILTER") = ""
  Application("HOST_FILTER") = ""
  Application("SPELL_CHECK_ID") = 0699209811

  Dim objConn, rst

  Set objConn = Server.CreateObject("ADODB.Connection")
  objConn.ConnectionTimeout = Application("TX_Timeout")
  objConn.Open Application("ConnectionString")

  Set rst = Server.CreateObject("ADODB.RecordSet")
  rst.CursorLocation = 3
  rst.CursorType = 0
  rst.LockType = 1
  rst.Open "SELECT [CID], [Title] FROM [Categories]", objConn
  Application("Categories") = rst.GetRows()
  rst.Close
  rst.Open "SELECT [BID], [Title], [Category] FROM [Boards]", objConn
  Application("Boards") = rst.GetRows()
  rst.Close
  Set rst = Nothing
  objConn.Close
  Set objConn = Nothing
End Sub

Sub Application_OnEnd
End Sub

Sub Session_OnStart
  Dim s

  Session("Rst_Topic") = 0
  Session("LastTopic") = -1
  Session("Usr_Logon") = False
  s = Split(Request.Cookies(Application("COOKIES") & "SESSION"), "A", 2)
  If UBound(s) = 1 Then
    If IsNumeric(s(0)) Then
      Dim objConn, rst

      Set objConn = Server.CreateObject("ADODB.Connection")
      objConn.ConnectionTimeout = Application("TX_Timeout")
      objConn.Open Application("ConnectionString")
      Set rst = Server.CreateObject("ADODB.RecordSet")
      rst.CursorLocation = 3
      rst.Open "SELECT * FROM [Session] WHERE [SID] = " & s(0) & " AND [Hash] = '" & s(1) & "'", objConn, 0, 1, &H0001
      If Not rst.EOF THen
        Session("Usr_Logon") = True
        Session("Usr_Username") = rst("Username").Value
      End If
      rst.Close
      Set rst = Nothing
      objConn.Close
      Set objConn = Nothing
    End If
  End If
End Sub

Sub Session_OnEnd
  If IsObject(Session("Rst_Topic")) Then Set Session("Rst_Topic") = Nothing
End Sub

</SCRIPT>