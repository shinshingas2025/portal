  Application("SHOW_IP_HOST") = 0
  Application("SHOW_TOTAL_MEMBERS") = 0
  Application("ATTACH_TYPE") = ""
  Application("TX_Timeout") = 5

  Application("COOKIES") = "WB"
  Application("WB_URL") = Application("WINBOARD_BASE")
  Application("IMAGE_URL") = Application("WINBOARD_BASE") & "/Public/Images"
  Application("UPLOAD_URL") = Application("WINBOARD_BASE") & "/Public/Uploads"
  Application("HTML_URL") = Application("WINBOARD_BASE") & "/Public/HTML"
