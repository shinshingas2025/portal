			myCommand.Parameters.Add("@CouncilMeetingNumber", SqlDbType.Int, 4).Value = councilMeetingNumber
			myCommand.Parameters.Add("@CouncilAffair", SqlDbType.NVarChar, 256).Value = councilAffair
