			myCommand.Parameters.Add("@SectionNumber", SqlDbType.NVarChar, 16).Value = sectionNumber
			myCommand.Parameters.Add("@SectionMeetingNumber", SqlDbType.Int, 4).Value = sectionMeetingNumber
