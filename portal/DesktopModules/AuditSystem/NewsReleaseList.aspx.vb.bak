		Protected WithEvents LinkButtonNewsListTenPageUp As System.Web.UI.WebControls.LinkButton
		Protected WithEvents LinkButtonNewsListPageUp As System.Web.UI.WebControls.LinkButton
		Protected WithEvents PlaceHolderNewsListPageIndex As System.Web.UI.WebControls.PlaceHolder
		Protected WithEvents LinkButtonNewsListPageDown As System.Web.UI.WebControls.LinkButton
		Protected WithEvents LinkButtonNewsListTenPageDown As System.Web.UI.WebControls.LinkButton

