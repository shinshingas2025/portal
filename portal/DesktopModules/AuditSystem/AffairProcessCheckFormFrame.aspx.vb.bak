			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListMainBranch.Items.Add(myListItem)
				Next
			End If

			DropDownListMainBranchUndertaker.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(MainBranchUndertakerCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListMainBranchUndertaker.Items.Add(myListItem)
				Next
			End If

			DropDownListAssistOffice.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(AssistOfficeCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListAssistOffice.Items.Add(myListItem)
				Next
			End If

			DropDownListAssistBranch.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(AssistBranchCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListAssistBranch.Items.Add(myListItem)
				Next
			End If

			DropDownListAssociationMeetingNumber.Items.Clear()
			For i = 1 To 99
				myListItem = New ListItem
				myListItem.Value = CType(i, String)
				myListItem.Text = "第" & Microsoft.VisualBasic.Right("00" & CType(i, String), 2) & "次"

				DropDownListAssociationMeetingNumber.Items.Add(myListItem)
			Next

			DropDownListAssociationState.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(StateCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListAssociationState.Items.Add(myListItem)
				Next
			End If

			DropDownListCouncilMeetingNumber.Items.Clear()
			For i = 1 To 99
				myListItem = New ListItem
				myListItem.Value = CType(i, String)
				myListItem.Text = "第" & Microsoft.VisualBasic.Right("00" & CType(i, String), 2) & "次"

				DropDownListCouncilMeetingNumber.Items.Add(myListItem)
			Next

			DropDownListCouncilState.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(StateCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListCouncilState.Items.Add(myListItem)
				Next
			End If

			DropDownListBureauMeetingNumber.Items.Clear()
			For i = 1 To 99
				myListItem = New ListItem
				myListItem.Value = CType(i, String)
				myListItem.Text = "第" & Microsoft.VisualBasic.Right("00" & CType(i, String), 2) & "次"

				DropDownListBureauMeetingNumber.Items.Add(myListItem)
			Next

			DropDownListBureauState.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(StateCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListBureauState.Items.Add(myListItem)
				Next
			End If

			DropDownListSectionMeetingNumber.Items.Clear()
			For i = 1 To 99
				myListItem = New ListItem
				myListItem.Value = CType(i, String)
				myListItem.Text = "第" & Microsoft.VisualBasic.Right("00" & CType(i, String), 2) & "次"

				DropDownListSectionMeetingNumber.Items.Add(myListItem)
			Next

			DropDownListSectionState.Items.Clear()
			myNormalCodeDataSet = myNormalCodeDAO.GetEntitysByGroupID(StateCodeGroupID)
			myNormalCodeDataSet = UtilityObject.QueryPermissionFilter(myNormalCodeDataSet, CodeAuthorityTarget, Context.User.Identity.Name)
			myNormalCodeCount = myNormalCodeDataSet.Tables(0).Rows.Count
			If myNormalCodeCount > 0 Then
				For i = 0 To myNormalCodeCount - 1
					myCodeID = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myCodeName = CType(myNormalCodeDataSet.Tables(0).Rows(i).Item("Name"), String)

					myListItem = New ListItem
					myListItem.Value = myCodeID
					myListItem.Text = myCodeName

					DropDownListSectionState.Items.Add(myListItem)
				Next
			End If

			PlaceHolderAttribute.Controls.Clear()

			myAttributeCodeDataSet = myAttributeCodeDAO.GetEntitys()
			myAttributeCodeDataSet = UtilityObject.QueryPermissionFilter(myAttributeCodeDataSet, AttributeCodeAuthorityTarget, Context.User.Identity.Name)
			myAttributeCodeCount = myAttributeCodeDataSet.Tables(0).Rows.Count
			'only top 10 attribute code will display
			If myAttributeCodeCount > 10 Then
				myAttributeCodeCount = 10
			End If
			If myAttributeCodeCount > 0 Then

				myTable = New HtmlTable
				myTable.CellPadding = 0
				myTable.CellSpacing = 0
				myTable.Border = 1

				myTableRow = New HtmlTableRow

				For i = 0 To myAttributeCodeCount - 1
					myTableCell = New HtmlTableCell
					myTableCell.Align = "center"

					myAttributeCodeID = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
					myAttributeCodeTypeID = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("TypeID"), Integer)
					If myAttributeCodeTypeID = AttributeType.Normal Then
						'normal type
						myTableCell.Width = NormalAttributeWidth
						myCheckBox = New CheckBox
						myCheckBox.ID = "Attribute" & myAttributeCodeID
						myTableCell.Controls.Add(myCheckBox)
					Else
						If myAttributeCodeTypeID = AttributeType.NewsRelease Then
							'news release attribute
							myTableCell.Width = NewsAttributeWidth
							myTextBox = New TextBox
							myTextBox.Width = Unit.Pixel(CType(NewsAttributeWidth, Integer))
							myTextBox.ID = "Attribute" & myAttributeCodeID
							myTextBox.Attributes("OnClick") = "window.open('NewsReleaseList.aspx?ReturnObjectID=" & myTextBox.ClientID & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"
							myTableCell.Controls.Add(myTextBox)
						Else
							If myAttributeCodeTypeID = AttributeType.CouncilmanInstruction Then
								'councilman instruction attribute
								myTableCell.Width = InstructionAttributeWidth
								myTextBox = New TextBox
								myTextBox.Width = Unit.Pixel(CType(InstructionAttributeWidth, Integer))
								myTextBox.ID = "Attribute" & myAttributeCodeID
								myTextBox.Attributes("OnClick") = "window.open('CouncilmanInstructionList.aspx?ReturnObjectID=" & myTextBox.ClientID & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"
								myTableCell.Controls.Add(myTextBox)
							Else
								If myAttributeCodeTypeID = AttributeType.Law Then
									'law attribute
									myTableCell.Width = LawAttributeWidth
									myTextBox = New TextBox
									myTextBox.Width = Unit.Pixel(CType(LawAttributeWidth, Integer))
									myTextBox.ID = "Attribute" & myAttributeCodeID
									myTextBox.Attributes("OnClick") = "window.open('LawList.aspx?ReturnObjectID=" & myTextBox.ClientID & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"
									myTableCell.Controls.Add(myTextBox)
								Else
									'exception:unknown attribute type
								End If
							End If
						End If
					End If

					myTableRow.Cells.Add(myTableCell)
				Next

				myTable.Controls.Add(myTableRow)

				PlaceHolderAttribute.Controls.Add(myTable)
			End If

			PlaceHolderAttribute.Visible = False

			PlaceHolderAssociationScheduleLink.Visible = False
			PlaceHolderCouncilScheduleLink.Visible = False
			PlaceHolderBureauScheduleLink.Visible = False
			PlaceHolderSectionScheduleLink.Visible = False
		End Sub
		Private Function SaveFormData(ByVal myFormID As String) As String
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim myFormDataSet As DataSet
			Dim delimStr As String = "/-:. "
			Dim delimiter As Char() = delimStr.ToCharArray()
			Dim tempString As String = ""
			Dim tempArray As String() = Nothing
			Dim myAffairID As String = ""
			Dim myPriorityID As String = ""
			Dim myMainOfficeID As String = ""
			Dim myMainBranchID As String = ""
			Dim myMainBranchUndertakerID As String = ""
			Dim myAssistOfficeID As String = ""
			Dim myAssistBranchID As String = ""
			Dim myAssociationNumber As String = ""
			Dim myAssociationMeetingNumber As Integer = 0
			Dim myAssociationAffair As String = ""
			Dim myAssociationDate As Date = New Date(1900, 1, 1)
			Dim myAssociationForecastDate As Date = New Date(1900, 1, 1)
			Dim myAssociationStateID As String = ""
			Dim myCouncilNumber As String = ""
			Dim myCouncilMeetingNumber As Integer = 0
			Dim myCouncilAffair As String = ""
			Dim myCouncilDate As Date = New Date(1900, 1, 1)
			Dim myCouncilForecastDate As Date = New Date(1900, 1, 1)
			Dim myCouncilStateID As String = ""
			Dim myBureauNumber As String = ""
			Dim myBureauMeetingNumber As Integer = 0
			Dim myBureauAffair As String = ""
			Dim myBureauDate As Date = New Date(1900, 1, 1)
			Dim myBureauForecastDate As Date = New Date(1900, 1, 1)
			Dim myBureauStateID As String = ""
			Dim mySectionNumber As String = ""
			Dim mySectionMeetingNumber As Integer = 0
			Dim mySectionAffair As String = ""
			Dim mySectionDate As Date = New Date(1900, 1, 1)
			Dim mySectionForecastDate As Date = New Date(1900, 1, 1)
			Dim mySectionStateID As String = ""
			Dim myAuthorityBO As New ContextAuthBO

			myAffairID = DropDownListAffair.SelectedValue
			myPriorityID = DropDownListPriority.SelectedValue
			myMainOfficeID = DropDownListMainOffice.SelectedValue
			myMainBranchID = DropDownListMainBranch.SelectedValue
			myMainBranchUndertakerID = DropDownListMainBranchUndertaker.SelectedValue
			myAssistOfficeID = DropDownListAssistOffice.SelectedValue
			myAssistBranchID = DropDownListAssistBranch.SelectedValue
			myAssociationNumber = TextBoxAssociationNumber.Text
			myAssociationMeetingNumber = CType(DropDownListAssociationMeetingNumber.SelectedValue, Integer)
			myAssociationAffair = TextBoxAssociationAffair.Text
			If TextBoxAssociationDate.Text.Trim <> "" Then
				tempString = TextBoxAssociationDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myAssociationDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			If TextBoxAssociationForecastDate.Text.Trim <> "" Then
				tempString = TextBoxAssociationForecastDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myAssociationForecastDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			myAssociationStateID = DropDownListAssociationState.SelectedValue
			myCouncilNumber = TextBoxCouncilNumber.Text
			myCouncilMeetingNumber = CType(DropDownListCouncilMeetingNumber.SelectedValue, Integer)
			myCouncilAffair = TextBoxCouncilAffair.Text
			If TextBoxCouncilDate.Text.Trim <> "" Then
				tempString = TextBoxCouncilDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myCouncilDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			If TextBoxCouncilForecastDate.Text.Trim <> "" Then
				tempString = TextBoxCouncilForecastDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myCouncilForecastDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			myCouncilStateID = DropDownListCouncilState.SelectedValue
			myBureauNumber = TextBoxBureauNumber.Text
			myBureauMeetingNumber = CType(DropDownListBureauMeetingNumber.SelectedValue, Integer)
			myBureauAffair = TextBoxBureauAffair.Text
			If TextBoxBureauDate.Text.Trim <> "" Then
				tempString = TextBoxBureauDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myBureauDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			If TextBoxBureauForecastDate.Text.Trim <> "" Then
				tempString = TextBoxBureauForecastDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					myBureauForecastDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			myBureauStateID = DropDownListBureauState.SelectedValue
			mySectionNumber = TextBoxSectionNumber.Text
			mySectionMeetingNumber = CType(DropDownListSectionMeetingNumber.SelectedValue, Integer)
			mySectionAffair = TextBoxSectionAffair.Text
			If TextBoxSectionDate.Text.Trim <> "" Then
				tempString = TextBoxSectionDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					mySectionDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			If TextBoxSectionForecastDate.Text.Trim <> "" Then
				tempString = TextBoxSectionForecastDate.Text.Trim
				tempArray = tempString.Split(delimiter)
				If tempArray.Length = 3 Then
					mySectionForecastDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
				End If
			End If
			mySectionStateID = DropDownListSectionState.SelectedValue

			If myFormID.Trim.Length > 0 Then
				'update
				myFormDataSet = myFormDAO.GetEntitysByEntityID(myFormID)
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					If groupID.Trim.Length > 0 Then
						'get authority
						If myAuthorityBO.CheckPurview(FormAuthorityTarget, myFormID, Context.User.Identity.Name, "U") Then
							myFormDAO.UpdateEntity(myFormID, groupID, myAffairID, myPriorityID, myMainOfficeID, myMainBranchID, myMainBranchUndertakerID, myAssistOfficeID, myAssistBranchID, myAssociationNumber, myAssociationMeetingNumber, myAssociationAffair, myAssociationDate, myAssociationForecastDate, myAssociationStateID, myCouncilNumber, myCouncilMeetingNumber, myCouncilAffair, myCouncilDate, myCouncilForecastDate, myCouncilStateID, myBureauNumber, myBureauMeetingNumber, myBureauAffair, myBureauDate, myBureauForecastDate, myBureauStateID, mySectionNumber, mySectionMeetingNumber, mySectionAffair, mySectionDate, mySectionForecastDate, mySectionStateID, Context.User.Identity.Name, Now)
						End If
					Else
						'exception:group id is empty
					End If
				Else
					'exception:form record is empty or duplicated
				End If
			Else
				'insert new data
				If groupID.Trim.Length > 0 Then
					myFormID = myFormDAO.InsertEntity(groupID, 0, DefaultPermissionGroup, DefaultPermission, myAffairID, myPriorityID, myMainOfficeID, myMainBranchID, myMainBranchUndertakerID, myAssistOfficeID, myAssistBranchID, myAssociationNumber, myAssociationMeetingNumber, myAssociationAffair, myAssociationDate, myAssociationForecastDate, myAssociationStateID, myCouncilNumber, myCouncilMeetingNumber, myCouncilAffair, myCouncilDate, myCouncilForecastDate, myCouncilStateID, myBureauNumber, myBureauMeetingNumber, myBureauAffair, myBureauDate, myBureauForecastDate, myBureauStateID, mySectionNumber, mySectionMeetingNumber, mySectionAffair, mySectionDate, mySectionForecastDate, mySectionStateID, Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
				Else
					'exception:group id is empty
				End If
			End If
			Return myFormID
		End Function
		Private Sub ButtonInsert_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonInsert.Click
			Dim myFormID As String = ""
			myFormID = SaveFormData("")
			Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myFormID)
		End Sub

		Private Sub ButtonUpdate_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonUpdate.Click
			If formID.Trim.Length > 0 Then
				SaveFormData(formID)
				Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & formID)
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub DeleteProcess(ByVal myFormID As String)
			Dim myProcessMapDAO As New AffairProcessMapDAOExtand
			Dim myProcessMapDataSet As DataSet
			Dim myProcessMapCount As Integer = 0
			Dim myProcessID As String = ""
			Dim i As Integer = 0
			Dim myAuthorityBO As New ContextAuthBO

			If myFormID.Trim.Length > 0 Then
				myProcessMapCount = myProcessMapDAO.GetTotalRowByFormID(myFormID)
				If myProcessMapCount > 0 Then
					myProcessMapDataSet = myProcessMapDAO.GetEntitysByFormID(myFormID)
					For i = 0 To myProcessMapCount - 1
						myProcessID = CType(myProcessMapDataSet.Tables(0).Rows(i).Item("EntityID"), String)
						DeleteProcessAttribute(myProcessID)
						'get authority
						If myAuthorityBO.CheckPurview(ProcessAuthorityTarget, myProcessID, Context.User.Identity.Name, "D") Then
							myProcessMapDAO.DeleteEntity(myProcessID)
						End If
					Next
				End If
			Else
				'exception:form id is empty
			End If
		End Sub
		Public Sub DeleteFormData(ByVal myFormID As String)
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim myFormDataSet As DataSet
			Dim myAuthorityBO As New ContextAuthBO

			If myFormID.Trim.Length > 0 Then
				myFormDataSet = myFormDAO.GetEntitysByEntityID(myFormID)
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					'delete
					DeleteProcess(myFormID)
					'get authority
					If myAuthorityBO.CheckPurview(FormAuthorityTarget, myFormID, Context.User.Identity.Name, "D") Then
						myFormDAO.DeleteEntity(myFormID)
					End If
				Else
					'exception:form record is empty or duplicated
				End If
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub ButtonDelete_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonDelete.Click
			If formID.Trim.Length > 0 Then
				DeleteFormData(formID)

				formID = ""
				Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID)
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub ButtonPrevious_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonPrevious.Click
			Dim myFormDataSet As DataSet
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim i As Integer = 0
			Dim myGroupID As String = ""
			Dim myItemID As Integer = 0
			Dim myPreviousID As String = ""
			Dim bFound As Boolean = False

			If formID.Trim.Length > 0 Then
				myPreviousID = formID
				myFormDataSet = myFormDAO.GetEntitysByEntityID(formID)
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					myGroupID = CType(myFormDataSet.Tables(0).Rows(0).Item("GroupID"), String)
					myItemID = CType(myFormDataSet.Tables(0).Rows(0).Item("ItemID"), Integer)
					'read total entity id and item id in group
					myFormDataSet = myFormDAO.GetItemIDByGroupID(myGroupID)
					myFormDataSet = UtilityObject.QueryPermissionFilter(myFormDataSet, FormAuthorityTarget, Context.User.Identity.Name)
					If myFormDataSet.Tables(0).Rows.Count > 0 Then
						For i = 0 To myFormDataSet.Tables(0).Rows.Count - 1
							If myItemID = CType(myFormDataSet.Tables(0).Rows(i).Item("ItemID"), Integer) Then
								bFound = True
								Exit For
							Else
								'save previous id
								myPreviousID = CType(myFormDataSet.Tables(0).Rows(i).Item("EntityID"), String)
							End If
						Next
						If bFound = True Then
							Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myPreviousID)
						End If
					End If
				Else
					'exception:form record is empty or duplicated
				End If
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub ButtonNext_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonNext.Click
			Dim myFormDataSet As DataSet
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim i As Integer = 0
			Dim myGroupID As String = ""
			Dim myItemID As Integer = 0
			Dim myNextID As String = ""
			Dim bFound As Boolean = False

			If formID.Trim.Length > 0 Then
				myNextID = formID
				myFormDataSet = myFormDAO.GetEntitysByEntityID(formID)
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					myGroupID = CType(myFormDataSet.Tables(0).Rows(0).Item("GroupID"), String)
					myItemID = CType(myFormDataSet.Tables(0).Rows(0).Item("ItemID"), Integer)
					'read total entity id and item id in group
					myFormDataSet = myFormDAO.GetItemIDByGroupID(myGroupID)
					myFormDataSet = UtilityObject.QueryPermissionFilter(myFormDataSet, FormAuthorityTarget, Context.User.Identity.Name)
					If myFormDataSet.Tables(0).Rows.Count > 0 Then
						For i = 0 To myFormDataSet.Tables(0).Rows.Count - 1
							If myItemID = CType(myFormDataSet.Tables(0).Rows(i).Item("ItemID"), Integer) Then
								bFound = True
								Exit For
							End If
						Next
						If bFound = True Then
							'save next id
							If i + 1 < myFormDataSet.Tables(0).Rows.Count Then
								myNextID = CType(myFormDataSet.Tables(0).Rows(i + 1).Item("EntityID"), String)
							Else
								myNextID = CType(myFormDataSet.Tables(0).Rows(myFormDataSet.Tables(0).Rows.Count - 1).Item("EntityID"), String)
							End If
							Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myNextID)
						End If
					End If
				Else
					'exception:form record is empty or duplicated
				End If
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub DeleteProcessAttribute(ByVal myProcessID As String)
			Dim myAttributeCodeDAO As New ProcessAttributeCodeDAOExtand
			Dim myAttributeMapDAO As New ProcessAttributeMapDAOExtand
			Dim myAttributeMapDataSet As DataSet
			Dim myAttributeMapCount As Integer = 0
			Dim i As Integer = 0
			Dim myAttributeID As String = ""
			Dim myAttributeCodeID As String = ""
			Dim myAuthorityBO As New ContextAuthBO

			If myProcessID.Trim.Length > 0 Then
				myAttributeMapCount = myAttributeMapDAO.GetTotalRowByProcessID(myProcessID)
				If myAttributeMapCount > 0 Then
					myAttributeMapDataSet = myAttributeMapDAO.GetEntitysByProcessID(myProcessID)
					For i = 0 To myAttributeMapCount - 1
						myAttributeID = CType(myAttributeMapDataSet.Tables(0).Rows(i).Item("EntityID"), String)
						myAttributeCodeID = CType(myAttributeMapDataSet.Tables(0).Rows(i).Item("AttributeID"), String)
						'get authority
						If myAuthorityBO.CheckPurview(AttributeAuthorityTarget, myAttributeID, Context.User.Identity.Name, "D") Then
							myAttributeMapDAO.DeleteEntity(myAttributeID)
						End If
						'alter display order
						myAttributeCodeDAO.DecreaseDisplayOrder(myAttributeCodeID, 1)
					Next
				End If
			Else
				'exception:process id is empty
			End If
		End Sub
		Private Sub SaveProcessAttribute(ByVal myProcessID As String)
			Dim myAttributeMapDAO As New ProcessAttributeMapDAOExtand
			Dim myAttributeCodeDAO As New ProcessAttributeCodeDAOExtand
			Dim myAttributeCodeDataSet As DataSet
			Dim myAttributeCodeCount As Integer = 0
			Dim myAttributeCodeID As String = ""
			Dim myAttributeCodeType As Integer = 0
			Dim i As Integer = 0
			Dim myAuthorityBO As New ContextAuthBO

			If myProcessID.Trim.Length > 0 Then
				myAttributeCodeDataSet = myAttributeCodeDAO.GetEntitys()
				myAttributeCodeDataSet = UtilityObject.QueryPermissionFilter(myAttributeCodeDataSet, AttributeCodeAuthorityTarget, Context.User.Identity.Name)
				myAttributeCodeCount = myAttributeCodeDataSet.Tables(0).Rows.Count

				If myAttributeCodeCount > 0 Then
					For i = 0 To myAttributeCodeCount - 1
						myAttributeCodeID = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("EntityID"), String)
						myAttributeCodeType = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("TypeID"), Integer)
						If myAttributeCodeType = AttributeType.Normal Then
							'normal attribute
							If Not (Request.Params("Attribute" & myAttributeCodeID) Is Nothing) Then
								If Request.Params("Attribute" & myAttributeCodeID) = "on" Then
									myAttributeMapDAO.InsertEntity(myProcessID, 0, DefaultPermissionGroup, DefaultPermission, myAttributeCodeID, "1", Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
									'alter display order
									myAttributeCodeDAO.IncreaseDisplayOrder(myAttributeCodeID, 1)
								End If
							End If
						Else
							If myAttributeCodeType = AttributeType.NewsRelease Then
								'news release attribute
								If Not (Request.Params("Attribute" & myAttributeCodeID) Is Nothing) Then
									If Request.Params("Attribute" & myAttributeCodeID).Trim.Length > 0 Then
										myAttributeMapDAO.InsertEntity(myProcessID, 0, DefaultPermissionGroup, DefaultPermission, myAttributeCodeID, Request.Params("Attribute" & myAttributeCodeID).Trim, Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
										'alter display order
										myAttributeCodeDAO.IncreaseDisplayOrder(myAttributeCodeID, 1)
									End If
								End If
							Else
								If myAttributeCodeType = AttributeType.CouncilmanInstruction Then
									'councilman instruction attribute
									If Not (Request.Params("Attribute" & myAttributeCodeID) Is Nothing) Then
										If Request.Params("Attribute" & myAttributeCodeID).Trim.Length > 0 Then
											myAttributeMapDAO.InsertEntity(myProcessID, 0, DefaultPermissionGroup, DefaultPermission, myAttributeCodeID, Request.Params("Attribute" & myAttributeCodeID).Trim, Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
											'alter display order
											myAttributeCodeDAO.IncreaseDisplayOrder(myAttributeCodeID, 1)
										End If
									End If
								Else
									If myAttributeCodeType = AttributeType.Law Then
										'law attribute
										If Not (Request.Params("Attribute" & myAttributeCodeID) Is Nothing) Then
											If Request.Params("Attribute" & myAttributeCodeID).Trim.Length > 0 Then
												myAttributeMapDAO.InsertEntity(myProcessID, 0, DefaultPermissionGroup, DefaultPermission, myAttributeCodeID, Request.Params("Attribute" & myAttributeCodeID).Trim, Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
												'alter display order
												myAttributeCodeDAO.IncreaseDisplayOrder(myAttributeCodeID, 1)
											End If
										End If
									Else
										'exception:unknown attribute type
									End If
								End If
							End If
						End If
					Next
				End If
			Else
				'exception:process id is empty
			End If
		End Sub
		Private Sub ButtonProcessUpdate_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonProcessUpdate.Click
			Dim delimStr As String = "/-:. "
			Dim delimiter As Char() = delimStr.ToCharArray()
			Dim tempString As String = ""
			Dim tempArray As String() = Nothing
			Dim myProcessMapDAO As New AffairProcessMapDAOExtand
			Dim myProcessDate As Date = New Date(1900, 1, 1)
			Dim myProcessState As String = "'"
			Dim myNote As String = ""
			Dim myProcessID As String = ""
			Dim myAuthorityBO As New ContextAuthBO

			If formID.Trim.Length > 0 Then
				'process date
				If TextBoxProcessDate.Text.Trim <> "" Then
					tempString = TextBoxProcessDate.Text.Trim
					tempArray = tempString.Split(delimiter)
					If tempArray.Length = 3 Then
						myProcessDate = New Date(CType(tempArray(0), Integer), CType(tempArray(1), Integer), CType(tempArray(2), Integer))
					End If
				End If
				'process state
				If TextBoxProcessState.Text.Trim <> "" Then
					myProcessState = TextBoxProcessState.Text.Trim
				End If
				'process note
				If TextBoxNote.Text.Trim <> "" Then
					myNote = TextBoxNote.Text.Trim
				End If

				If processID.Trim.Length > 0 Then
					If action.Trim.Length > 0 Then
						If action.Trim = "update" Then
							'get authority
							If myAuthorityBO.CheckPurview(ProcessAuthorityTarget, processID, Context.User.Identity.Name, "U") Then
								'update
								myProcessMapDAO.UpdateEntity(processID, myProcessDate, myProcessState, myNote, Context.User.Identity.Name, Now)
								DeleteProcessAttribute(processID)
								SaveProcessAttribute(processID)
								Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & formID)
							Else
								PageLoad()
							End If
						Else
							If action.Trim = "delete" Then
								'get authority
								If myAuthorityBO.CheckPurview(ProcessAuthorityTarget, processID, Context.User.Identity.Name, "D") Then
									'delete
									DeleteProcessAttribute(processID)
									myProcessMapDAO.DeleteEntity(processID)
									Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & formID)
								Else
									PageLoad()
								End If
							Else
								'exception:unknown action
							End If
						End If
					Else
						'exception:no action
					End If
				Else
					'insert
					myProcessID = myProcessMapDAO.InsertEntity(formID, 0, DefaultPermissionGroup, DefaultPermission, myProcessDate, myProcessState, myNote, Context.User.Identity.Name, Now, Context.User.Identity.Name, Now, 1, New Date(1900, 1, 1))
					SaveProcessAttribute(myProcessID)
					Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & formID)
				End If
			Else
				'exception:form id is empty
			End If
		End Sub

		Private Sub DropDownListMainOffice_SelectedIndexChanged(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles DropDownListMainOffice.SelectedIndexChanged
			Dim myMainOfficeID As String = ""
			myMainOfficeID = DropDownListMainOffice.SelectedValue
			Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & myMainOfficeID)
		End Sub

		Private Sub FillProcessHistory(ByVal myGroupID As String, ByVal myAffairID As String)
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim myFormDataSet As DataSet
			Dim myFormCount As Integer = 0
			Dim myFormID As String = ""
			Dim myProcessDAO As New AffairProcessMapDAOExtand
			Dim myProcessDataSet As DataSet
			Dim myProcessCount As Integer = 0
			Dim myProcessState As String = ""
			Dim i As Integer = 0
			Dim j As Integer = 0
			Dim myTable As HtmlTable
			Dim myTableRow As HtmlTableRow
			Dim myTableCell As HtmlTableCell
			Dim myLabel As LiteralControl
			Dim myButton As Button

			PlaceHolderProcessHistory.Controls.Clear()

			If myGroupID.Trim.Length > 0 And myAffairID.Trim.Length > 0 Then
				myFormDataSet = myFormDAO.GetEntitysByGroupIDAndAffairID(groupID, myAffairID)
				myFormDataSet = UtilityObject.QueryPermissionFilter(myFormDataSet, FormAuthorityTarget, Context.User.Identity.Name)
				myFormCount = myFormDataSet.Tables(0).Rows.Count

				If myFormCount > 0 Then
					myTable = New HtmlTable
					myTable.Width = "100%"
					myTable.CellPadding = 0
					myTable.CellSpacing = 0
					myTable.Border = 1

					For i = 0 To myFormCount - 1
						myFormID = CType(myFormDataSet.Tables(0).Rows(i).Item("EntityID"), String)

						myProcessCount = myProcessDAO.GetTotalRowByFormID(myFormID)
						If myProcessCount > 0 Then
							myProcessDataSet = myProcessDAO.GetEntitysByFormID(myFormID)
							For j = 0 To myProcessCount - 1
								myProcessState = CType(myProcessDataSet.Tables(0).Rows(j).Item("ProcessState"), String).Trim

								myTableRow = New HtmlTableRow
								'process state
								myTableCell = New HtmlTableCell
								myLabel = New LiteralControl
								myLabel.Text = myProcessState
								myTableCell.Controls.Add(myLabel)
								myTableRow.Cells.Add(myTableCell)
								'import button
								myTableCell = New HtmlTableCell
								myTableCell.Width = ActionWidth
								myButton = New Button
								myButton.CssClass = "nav"
								myButton.Text = "輸入"
								myButton.Attributes("OnClick") = "document.Form1." & Me.TextBoxProcessState.ClientID & ".value=" & Chr(34) & myProcessState & Chr(34)
								myTableCell.Controls.Add(myButton)
								myTableRow.Cells.Add(myTableCell)

								myTable.Controls.Add(myTableRow)
							Next
						End If
					Next

					PlaceHolderProcessHistory.Controls.Add(myTable)
				End If
			Else
				'exception:group id or affair id is empty
			End If
		End Sub
		Protected Sub DropDownListAffair_SelectedIndexChanged(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles DropDownListAffair.SelectedIndexChanged
			Dim myAffairID As String = ""
			myAffairID = DropDownListAffair.SelectedValue

			If groupID.Trim.Length > 0 Then
				FillProcessHistory(groupID, myAffairID)
			Else
				'exception:group id is empty
			End If
		End Sub

		Private Sub ButtonProcessMore_Click(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles ButtonProcessMore.Click
			Dim myProcessID As String = ""
			If formID.Trim.Length > 0 Then
				If processID.Trim.Length > 0 Then
					Response.Redirect("~/DesktopModules/AuditSystem/ProcessAttributeCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&formID=" & formID & "&processID=" & processID)
				Else
					Response.Redirect("~/DesktopModules/AuditSystem/ProcessAttributeCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&formID=" & formID)
				End If
			Else
				'exception:form id is empty
			End If
		End Sub
	End Class
End Namespace