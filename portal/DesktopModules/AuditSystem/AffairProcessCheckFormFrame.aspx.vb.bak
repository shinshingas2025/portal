		Private Sub Page_Load(ByVal sender As System.Object, ByVal e As System.EventArgs) Handles MyBase.Load
			'在這裡放置使用者程式碼以初始化網頁()
			'Session("sid") = "9999"
			'If PortalSecurity.IsInRoles("Admins") = False Then
			'    Response.Redirect("~/Admin/EditAccessDenied.aspx")
			'End If
			' Calculate userid
			If Not (Request.Params("sid") Is Nothing) Then
				sid = Request.Params("sid")
			End If

			If Not (Request.Params("tabid") Is Nothing) Then
				tabId = Int32.Parse(Request.Params("tabid"))
			End If

			If Not (Request.Params("tabindex") Is Nothing) Then
				tabIndex = Int32.Parse(Request.Params("tabindex"))
			End If

			If Not (Request.Params("mid") Is Nothing) Then
				moduleId = Int32.Parse(Request.Params("mid"))
			End If

			If Not (Request.Params("formID") Is Nothing) Then
				formID = Request.Params("formID")
			End If

			If Not (Request.Params("processID") Is Nothing) Then
				processID = Request.Params("processID")
			End If

			If Not (Request.Params("groupID") Is Nothing) Then
				groupID = Request.Params("groupID")
				'Else
				'groupID = "200601010000000300000001"
			End If

			'AlterAffairCodeGroup(groupID)

			If Not (Request.Params("action") Is Nothing) Then
				action = Request.Params("action")
			End If

			If Not IsPostBack Then
				If Not (Request.UrlReferrer Is Nothing) Then
					ViewState("UrlReferrer") = Request.UrlReferrer.ToString()
				End If
				PageLoad()
			End If
		End Sub

		Private Sub PageLoad()
			Dim myFormDAO As New AffairProcessCheckFormDAOExtand
			Dim myFormDataSet As DataSet
			Dim myFormID As String = ""
			Dim myGroupID As String = ""

			If formID.Trim.Length > 0 Then
				myFormDataSet = myFormDAO.GetEntitysByEntityID(formID)
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					myGroupID = CType(myFormDataSet.Tables(0).Rows(0).Item("GroupID"), String)

					groupID = myGroupID

					AlterAffairCodeGroup(myGroupID)
				Else
					'exception:form record is empty or duplicated
				End If
			Else
				If groupID.Trim.Length = 0 Then
					groupID = "200601010000000300000001"
					AffairCodeGroupID = "2006010100000011"
				End If
				If groupID.Trim.Length > 0 Then
					myFormDataSet = myFormDAO.GetEntitysByGroupID(groupID)
					myFormDataSet = UtilityObject.QueryPermissionFilter(myFormDataSet, FormAuthorityTarget, Context.User.Identity.Name, 1)

					If myFormDataSet.Tables(0).Rows.Count = 1 Then
						myFormID = CType(myFormDataSet.Tables(0).Rows(0).Item("EntityID"), String)
						Response.Redirect("~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myFormID)
					End If
				Else
					'exception:group id is empty
				End If
			End If

			InitialWebControl()

			FillFormData(myFormDataSet)
		End Sub

		Private Sub AlterAffairCodeGroup(ByVal myGroupID As String)
			If myGroupID = "200601010000000300000001" Then
				AffairCodeGroupID = "2006010100000011"
			Else
				If myGroupID = "200601010000000300000002" Then
					AffairCodeGroupID = "2006010100000012"
				Else
					If myGroupID = "200601010000000300000003" Then
						AffairCodeGroupID = "2006010100000013"
					Else
						If myGroupID = "200601010000000300000004" Then
							AffairCodeGroupID = "2006010100000014"
						Else
							If myGroupID = "200601010000000300000005" Then
								AffairCodeGroupID = "2006010100000015"
							Else
								If myGroupID = "200601010000000300000006" Then
									AffairCodeGroupID = "2006010100000016"
								Else
									If myGroupID = "200601010000000300000007" Then
										AffairCodeGroupID = "2006010100000017"
									Else
										If myGroupID = "200601010000000300000008" Then
											AffairCodeGroupID = "2006010100000018"
										Else
											'exception:unknown group
										End If
									End If
								End If
							End If
						End If
					End If
				End If
			End If
		End Sub
		Private Sub FillFormData(ByVal myFormDataSet As DataSet)
			Dim myGroupID As String = ""
			Dim myFormID As String = ""
			Dim myAffairID As String = ""
			Dim myPriorityID As String = ""
			Dim myMainOfficeID As String = ""
			Dim myMainBranchID As String = ""
			Dim myMainBranchUndertakerID As String = ""
			Dim myAssistOfficeID As String = ""
			Dim myAssistBranchID As String = ""
			Dim myAssociationNumber As String = ""
			Dim myAssociationMeetingNumber As Integer = 0
			Dim myAssociationAffair As String = ""
			Dim myAssociationDate As Date
			Dim myAssociationForecastDate As Date
			Dim myAssociationStateID As String = ""
			Dim myCouncilNumber As String = ""
			Dim myCouncilMeetingNumber As Integer = 0
			Dim myCouncilAffair As String = ""
			Dim myCouncilDate As Date
			Dim myCouncilForecastDate As Date
			Dim myCouncilStateID As String = ""
			Dim myBureauNumber As String = ""
			Dim myBureauMeetingNumber As Integer = 0
			Dim myBureauAffair As String = ""
			Dim myBureauDate As Date
			Dim myBureauForecastDate As Date
			Dim myBureauStateID As String = ""
			Dim mySectionNumber As String = ""
			Dim mySectionMeetingNumber As Integer = 0
			Dim mySectionAffair As String = ""
			Dim mySectionDate As Date
			Dim mySectionForecastDate As Date
			Dim mySectionStateID As String = ""
			Dim myResolutionContent As String = ""

			If Not (myFormDataSet Is Nothing) Then
				If myFormDataSet.Tables(0).Rows.Count = 1 Then
					myFormID = CType(myFormDataSet.Tables(0).Rows(0).Item("EntityID"), String)
					myGroupID = CType(myFormDataSet.Tables(0).Rows(0).Item("GroupID"), String)
					myAffairID = CType(myFormDataSet.Tables(0).Rows(0).Item("AffairID"), String)
					myPriorityID = CType(myFormDataSet.Tables(0).Rows(0).Item("PriorityID"), String)
					myMainOfficeID = CType(myFormDataSet.Tables(0).Rows(0).Item("MainOfficeID"), String)
					myMainBranchID = CType(myFormDataSet.Tables(0).Rows(0).Item("MainBranchID"), String)
					myMainBranchUndertakerID = CType(myFormDataSet.Tables(0).Rows(0).Item("MainBranchUndertakerID"), String)
					myAssistOfficeID = CType(myFormDataSet.Tables(0).Rows(0).Item("AssistOfficeID"), String)
					myAssistBranchID = CType(myFormDataSet.Tables(0).Rows(0).Item("AssistBranchID"), String)
					myAssociationNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationNumber"), String)
					myAssociationMeetingNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationMeetingNumber"), Integer)
					myAssociationAffair = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationAffair"), String)
					myAssociationDate = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationDate"), Date)
					myAssociationForecastDate = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationForecastDate"), Date)
					myAssociationStateID = CType(myFormDataSet.Tables(0).Rows(0).Item("AssociationStateID"), String)
					myCouncilNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilNumber"), String)
					myCouncilMeetingNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilMeetingNumber"), Integer)
					myCouncilAffair = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilAffair"), String)
					myCouncilDate = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilDate"), Date)
					myCouncilForecastDate = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilForecastDate"), Date)
					myCouncilStateID = CType(myFormDataSet.Tables(0).Rows(0).Item("CouncilStateID"), String)
					myBureauNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauNumber"), String)
					myBureauMeetingNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauMeetingNumber"), Integer)
					myBureauAffair = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauAffair"), String)
					myBureauDate = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauDate"), Date)
					myBureauForecastDate = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauForecastDate"), Date)
					myBureauStateID = CType(myFormDataSet.Tables(0).Rows(0).Item("BureauStateID"), String)
					mySectionNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionNumber"), String)
					mySectionMeetingNumber = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionMeetingNumber"), Integer)
					mySectionAffair = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionAffair"), String)
					mySectionDate = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionDate"), Date)
					mySectionForecastDate = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionForecastDate"), Date)
					mySectionStateID = CType(myFormDataSet.Tables(0).Rows(0).Item("SectionStateID"), String)

					myResolutionContent = GetMeetingRecordResolutionContent(myAssociationNumber, myAssociationMeetingNumber, myCouncilNumber, myCouncilMeetingNumber, myBureauNumber, myBureauMeetingNumber, mySectionNumber, mySectionMeetingNumber)

					LabelResolutionContent.Text = myResolutionContent

					Try
						DropDownListAffair.SelectedValue = myAffairID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListPriority.SelectedValue = myPriorityID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListMainOffice.SelectedValue = myMainOfficeID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListMainBranch.SelectedValue = myMainBranchID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListMainBranchUndertaker.SelectedValue = myMainBranchUndertakerID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListAssistOffice.SelectedValue = myAssistOfficeID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListAssistBranch.SelectedValue = myAssistBranchID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListAssociationMeetingNumber.SelectedValue = CType(myAssociationMeetingNumber, String)
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListAssociationState.SelectedValue = myAssociationStateID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListCouncilMeetingNumber.SelectedValue = CType(myCouncilMeetingNumber, String)
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListCouncilState.SelectedValue = myCouncilStateID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListBureauMeetingNumber.SelectedValue = CType(myBureauMeetingNumber, String)
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListBureauState.SelectedValue = myBureauStateID
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListSectionMeetingNumber.SelectedValue = CType(mySectionMeetingNumber, String)
					Catch ex As Exception
						'exception:no match
					End Try
					Try
						DropDownListSectionState.SelectedValue = mySectionStateID
					Catch ex As Exception
						'exception:no match
					End Try

					TextBoxAssociationAffair.Text = myAssociationAffair
					TextBoxAssociationNumber.Text = myAssociationNumber
					TextBoxAssociationDate.Text = myAssociationDate.Year & "/" & myAssociationDate.Month & "/" & myAssociationDate.Day
					If TextBoxAssociationDate.Text = "1900/1/1" Then
						TextBoxAssociationDate.Text = ""
					End If
					TextBoxAssociationForecastDate.Text = myAssociationForecastDate.Year & "/" & myAssociationForecastDate.Month & "/" & myAssociationForecastDate.Day
					If TextBoxAssociationForecastDate.Text = "1900/1/1" Then
						TextBoxAssociationForecastDate.Text = ""
					End If
					TextBoxCouncilAffair.Text = myCouncilAffair
					TextBoxCouncilNumber.Text = myCouncilNumber
					TextBoxCouncilDate.Text = myCouncilDate.Year & "/" & myCouncilDate.Month & "/" & myCouncilDate.Day
					If TextBoxCouncilDate.Text = "1900/1/1" Then
						TextBoxCouncilDate.Text = ""
					End If
					TextBoxCouncilForecastDate.Text = myCouncilForecastDate.Year & "/" & myCouncilForecastDate.Month & "/" & myCouncilForecastDate.Day
					If TextBoxCouncilForecastDate.Text = "1900/1/1" Then
						TextBoxCouncilForecastDate.Text = ""
					End If
					TextBoxBureauAffair.Text = myBureauAffair
					TextBoxBureauNumber.Text = myBureauNumber
					TextBoxBureauDate.Text = myBureauDate.Year & "/" & myBureauDate.Month & "/" & myBureauDate.Day
					If TextBoxBureauDate.Text = "1900/1/1" Then
						TextBoxBureauDate.Text = ""
					End If
					TextBoxBureauForecastDate.Text = myBureauForecastDate.Year & "/" & myBureauForecastDate.Month & "/" & myBureauForecastDate.Day
					If TextBoxBureauForecastDate.Text = "1900/1/1" Then
						TextBoxBureauForecastDate.Text = ""
					End If
					TextBoxSectionAffair.Text = mySectionAffair
					TextBoxSectionNumber.Text = mySectionNumber
					TextBoxSectionDate.Text = mySectionDate.Year & "/" & mySectionDate.Month & "/" & mySectionDate.Day
					If TextBoxSectionDate.Text = "1900/1/1" Then
						TextBoxSectionDate.Text = ""
					End If
					TextBoxSectionForecastDate.Text = mySectionForecastDate.Year & "/" & mySectionForecastDate.Month & "/" & mySectionForecastDate.Day
					If TextBoxSectionForecastDate.Text = "1900/1/1" Then
						TextBoxSectionForecastDate.Text = ""
					End If

					'process history
					FillProcessHistory(groupID, myAffairID)
					'process
					If myFormID.Trim.Length > 0 Then
						FillProcessData(myFormID)
					Else
						'exception:form id is empty
					End If

					'prepare schedule link
					FillScheduleLink(myAssociationNumber, myAssociationMeetingNumber, myCouncilNumber, myCouncilMeetingNumber, myBureauNumber, myBureauMeetingNumber, mySectionNumber, mySectionMeetingNumber)
				Else
					'exception:form record is empty or duplicated
				End If
			End If
		End Sub
		Private Sub FillScheduleLink(ByVal associationNumber As String, ByVal associationMeetingNumber As Integer, ByVal councilNumber As String, ByVal councilMeetingNumber As Integer, ByVal bureauNumber As String, ByVal bureauMeetingNumber As Integer, ByVal sectionNumber As String, ByVal sectionMeetingNumber As Integer)
			Dim myTitle As String = ""
			Dim myDescription As String = ""
			Dim myNote As String = ""
			Dim myAnchor As HtmlAnchor

			PlaceHolderAssociationScheduleLink.Visible = False
			PlaceHolderCouncilScheduleLink.Visible = False
			PlaceHolderBureauScheduleLink.Visible = False
			PlaceHolderSectionScheduleLink.Visible = False

			myAnchor = New HtmlAnchor
			myAnchor.Attributes("Class") = "scriptLink"
			myAnchor.InnerHtml = "<img src='/PortalFiles/WebImage/AuditSystem/link.gif' alt='行事曆' />"

			myDescription = GetMeetingRecordResolutionContent(associationNumber, associationMeetingNumber, councilNumber, councilMeetingNumber, bureauNumber, bureauMeetingNumber, sectionNumber, sectionMeetingNumber)

			If associationNumber.Trim.Length > 0 And associationMeetingNumber <> 0 Then
				myTitle = "第" & CType(associationMeetingNumber, String) & "次會本會議記錄"

				myAnchor.Attributes("OnClick") = "window.open('ScheduleInsert.aspx?inputTitle=" & ToUnicodeString(myTitle) & "&inputDescription=" & ToUnicodeString(myDescription) & "&inputNote=" & ToUnicodeString(myNote) & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"

				PlaceHolderAssociationScheduleLink.Controls.Add(myAnchor)
				PlaceHolderAssociationScheduleLink.Visible = True
			Else
				If councilNumber.Trim.Length > 0 And councilMeetingNumber <> 0 Then
					myTitle = "第" & CType(councilMeetingNumber, String) & "次委員會議記錄"

					myAnchor.Attributes("OnClick") = "window.open('ScheduleInsert.aspx?inputTitle=" & ToUnicodeString(myTitle) & "&inputDescription=" & ToUnicodeString(myDescription) & "&inputNote=" & ToUnicodeString(myNote) & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"

					PlaceHolderCouncilScheduleLink.Controls.Add(myAnchor)
					PlaceHolderCouncilScheduleLink.Visible = True
				Else
					If bureauNumber.Trim.Length > 0 And bureauMeetingNumber <> 0 Then
						myTitle = "第" & CType(bureauMeetingNumber, String) & "次局務會議記錄"

						myAnchor.Attributes("OnClick") = "window.open('ScheduleInsert.aspx?inputTitle=" & ToUnicodeString(myTitle) & "&inputDescription=" & ToUnicodeString(myDescription) & "&inputNote=" & ToUnicodeString(myNote) & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"

						PlaceHolderBureauScheduleLink.Controls.Add(myAnchor)
						PlaceHolderBureauScheduleLink.Visible = True
					Else
						If sectionNumber.Trim.Length > 0 And sectionMeetingNumber <> 0 Then
							myTitle = "第" & CType(sectionMeetingNumber, String) & "次組務會議記錄"

							myAnchor.Attributes("OnClick") = "window.open('ScheduleInsert.aspx?inputTitle=" & ToUnicodeString(myTitle) & "&inputDescription=" & ToUnicodeString(myDescription) & "&inputNote=" & ToUnicodeString(myNote) & "','','height=328,width=800,status=no,toolbar=no,menubar=no,location=no','')"

							PlaceHolderSectionScheduleLink.Controls.Add(myAnchor)
							PlaceHolderSectionScheduleLink.Visible = True
						End If
					End If
				End If
			End If
		End Sub
		Private Function ToUnicodeString(ByVal input As String) As String
			Dim myCharArray() As Char
			Dim myByte As Byte
			Dim result As String = ""
			Dim i As Integer = 0
			Dim uniEncoder As Encoder = Encoding.Unicode.GetEncoder()
			Dim byteCount As Integer = 0
			Dim myByteArray() As Byte
			Dim bytesEncodedCount As Integer = 0

			If input.Trim.Length > 0 Then
				myCharArray = input.ToCharArray()
				byteCount = uniEncoder.GetByteCount(myCharArray, 0, myCharArray.Length, True)
				myByteArray = New Byte(byteCount - 1) {}

				bytesEncodedCount = uniEncoder.GetBytes(myCharArray, 0, myCharArray.Length, myByteArray, 0, True)

				For i = 0 To bytesEncodedCount - 1
					myByte = New Byte
					myByte = myByteArray(i)
					result = result & Microsoft.VisualBasic.Right("00" & CType(Hex(Val(myByte)), String), 2)
				Next
			Else
				'exception:input string is empty
			End If
			Return result
		End Function
		Private Function GetMeetingRecordResolutionContent(ByVal associationNumber As String, ByVal associationMeetingNumber As Integer, ByVal councilNumber As String, ByVal councilMeetingNumber As Integer, ByVal bureauNumber As String, ByVal bureauMeetingNumber As Integer, ByVal sectionNumber As String, ByVal sectionMeetingNumber As Integer) As String
			Dim myRecordDAO As New MeetingRecordDAOExtand
			Dim myRecordCount As Integer = 0
			Dim myControlNumber As String = ""
			Dim myMeetingNumber As Integer = 0
			Dim myContent As String = ""

			If associationNumber.Trim.Length > 0 And associationMeetingNumber <> 0 Then
				myControlNumber = associationNumber.Trim
				myMeetingNumber = associationMeetingNumber
			Else
				If councilNumber.Trim.Length > 0 And councilMeetingNumber <> 0 Then
					myControlNumber = councilNumber.Trim
					myMeetingNumber = councilMeetingNumber
				Else
					If bureauNumber.Trim.Length > 0 And bureauMeetingNumber <> 0 Then
						myControlNumber = bureauNumber.Trim
						myMeetingNumber = bureauMeetingNumber
					Else
						If sectionNumber.Trim.Length > 0 And sectionMeetingNumber <> 0 Then
							myControlNumber = sectionNumber.Trim
							myMeetingNumber = sectionMeetingNumber
						End If
					End If
				End If
			End If

			If myControlNumber.Length > 0 And myMeetingNumber <> 0 Then
				myRecordCount = myRecordDAO.GetTotalRowByResolutionNumberAndMeetingNumber(myControlNumber, myMeetingNumber)
				If myRecordCount = 1 Then
					myContent = myRecordDAO.GetResolutionContentByResolutionNumberAndMeetingNumber(myControlNumber, myMeetingNumber)
				Else
					'exception:resolution is empty or duplicated
				End If
			Else
				'exception:control number or meeting number is empty
			End If

			Return myContent
		End Function
		Private Sub FillProcessData(ByVal myFormID As String)
			Dim myProcessMapDAO As New AffairProcessMapDAOExtand
			Dim myProcessMapDataSet As DataSet
			Dim myProcessMapCount As Integer = 0
			Dim myAttributeCodeDAO As New ProcessAttributeCodeDAOExtand
			Dim myAttributeCodeDataSet As DataSet
			Dim myAttributeMapDAO As New ProcessAttributeMapDAOExtand
			Dim myAttributeMapDataSet As DataSet
			Dim myAttributeMapCount As Integer = 0
			Dim myAttributeCodeCount As Integer = 0
			Dim myTable As HtmlTable
			Dim myTableRow As HtmlTableRow
			Dim myTableCell As HtmlTableCell
			Dim myProcessDate As Date = New Date(1900, 1, 1)
			Dim myProcessState As String = ""
			Dim myNote As String = ""
			Dim myInputText As HtmlInputText
			Dim myHyperLink As HyperLink
			Dim myLiterial As LiteralControl
			Dim myImage As HtmlImage
			Dim myProcessID As String = ""
			Dim myName As String = ""
			Dim myAttributeID As String = ""
			Dim myAttributeValue As String = ""
			Dim myAttributeType As Integer = 0
			Dim i As Integer = 0
			Dim j As Integer = 0
			Dim isChecked As Boolean
			Dim anItem As DataListItem
			Dim dk As String
			Dim myCheckBox As CheckBox
			Dim myTextBox As TextBox

			If myFormID.Trim.Length > 0 Then
				PlaceHolderProcess.Controls.Clear()
				myTable = New HtmlTable
				myTable.CellPadding = 0
				myTable.CellSpacing = 0
				myTable.Border = 1
				'prepare process header
				myTableRow = New HtmlTableRow
				myTableRow.BgColor = NormalProcessBGColor
				'action column header
				myTableCell = New HtmlTableCell
				myTableCell.Width = ActionWidth
				myTableRow.Cells.Add(myTableCell)
				'process date column header
				myTableCell = New HtmlTableCell
				myTableCell.Width = ProcessDateWidth
				myTableCell.InnerText = "處理日"
				myTableRow.Cells.Add(myTableCell)
				'process state column header
				myTableCell = New HtmlTableCell
				myTableCell.Width = ProcessStateWidth
				myTableCell.InnerText = "處理情形"
				myTableRow.Cells.Add(myTableCell)
				'note column header
				myTableCell = New HtmlTableCell
				myTableCell.Width = NoteWidth
				myTableCell.InnerText = "備註"
				myTableRow.Cells.Add(myTableCell)
				'process attribute column header
				myAttributeCodeDataSet = myAttributeCodeDAO.GetEntitys()
				myAttributeCodeDataSet = UtilityObject.QueryPermissionFilter(myAttributeCodeDataSet, AttributeCodeAuthorityTarget, Context.User.Identity.Name)
				myAttributeCodeCount = myAttributeCodeDataSet.Tables(0).Rows.Count
				'only top 10 attribute code will display
				If myAttributeCodeCount > 10 Then
					myAttributeCodeCount = 10
				End If
				If myAttributeCodeCount > 0 Then
					For i = 0 To myAttributeCodeCount - 1
						myName = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("Name"), String)
						myAttributeType = CType(myAttributeCodeDataSet.Tables(0).Rows(i).Item("TypeID"), Integer)
						myTableCell = New HtmlTableCell
						myTableCell.Align = "center"
						If myAttributeType = AttributeType.Normal Then
							'normal attribute
							myTableCell.Width = NormalAttributeWidth
						Else
							If myAttributeType = AttributeType.NewsRelease Then
								'news release attribute
								myTableCell.Width = NewsAttributeWidth
							Else
								If myAttributeType = AttributeType.CouncilmanInstruction Then
									'councilman instruction attribute
									myTableCell.Width = InstructionAttributeWidth
								Else
									If myAttributeType = AttributeType.Law Then
										'law attribute
										myTableCell.Width = LawAttributeWidth
									Else
										'exception:unknown attribute type
									End If
								End If
							End If
						End If
						myTableCell.InnerText = myName
						myTableRow.Cells.Add(myTableCell)
					Next
				End If

				myTable.Rows.Add(myTableRow)

				myProcessMapDataSet = myProcessMapDAO.GetEntitysByFormID(myFormID)
				myProcessMapDataSet = UtilityObject.QueryPermissionFilter(myProcessMapDataSet, ProcessAuthorityTarget, Context.User.Identity.Name)
				myProcessMapCount = myProcessMapDataSet.Tables(0).Rows.Count

				If myProcessMapCount > 0 Then
					For i = 0 To myProcessMapCount - 1
						myProcessID = CType(myProcessMapDataSet.Tables(0).Rows(i).Item("EntityID"), String)
						myTableRow = New HtmlTableRow
						If myProcessID = processID Then
							myTableRow.BgColor = FocusProcessBGColor
						Else
							myTableRow.BgColor = NormalProcessBGColor
						End If

						'insert icon
						myTableCell = New HtmlTableCell
						myTableCell.Align = "center"
						myTableCell.Width = ActionWidth
						'insert link
						myHyperLink = New HyperLink
						myHyperLink.NavigateUrl = "~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myFormID & "&processID=" & myProcessID & "&action=update"
						myHyperLink.ImageUrl = "~/images/edit.gif"
						myHyperLink.Text = "修改"
						myTableCell.Controls.Add(myHyperLink)
						'insert link
						myHyperLink = New HyperLink
						myHyperLink.NavigateUrl = "~/DesktopModules/AuditSystem/ProcessAttributeCheckViewFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&processID=" & myProcessID
						myHyperLink.ImageUrl = "~/images/rt.gif"
						myHyperLink.Text = "閱覽"
						myTableCell.Controls.Add(myHyperLink)
						''br
						'myLiterial = New LiteralControl
						'myLiterial.Text = "<BR>"
						'myTableCell.Controls.Add(myLiterial)
						'insert link
						myHyperLink = New HyperLink
						myHyperLink.NavigateUrl = "~/DesktopModules/AuditSystem/AffairProcessCheckFormFrame.aspx?sid=" & sid & "&mid=" & moduleId & "&tabid=" & tabId & "&tabindex=" & tabIndex & "&groupID=" & groupID & "&formID=" & myFormID & "&processID=" & myProcessID & "&action=delete"
						myHyperLink.ImageUrl = "~/images/delete.gif"
						myHyperLink.Text = "刪除"
						myTableCell.Controls.Add(myHyperLink)

						myTableRow.Cells.Add(myTableCell)

						'process date
						myProcessDate = CType(myProcessMapDataSet.Tables(0).Rows(i).Item("ProcessDate"), Date)
						myTableCell = New HtmlTableCell
						myTableCell.Width = ProcessDateWidth
						myTableCell.InnerText = myProcessDate.Year & "/" & myProcessDate.Month & "/" & myProcessDate.Day
						If myTableCell.InnerText = "1900/1/1" Then
							myTableCell.InnerText = ""
						End If
						myTableRow.Cells.Add(myTableCell)

						'process state
						myProcessState = CType(myProcessMapDataSet.Tables(0).Rows(i).Item("ProcessState"), String).Trim
						myTableCell = New HtmlTableCell
						myTableCell.Width = ProcessStateWidth
						myTableCell.InnerHtml = myProcessState
						myTableRow.Cells.Add(myTableCell)

						'note
						myNote = CType(myProcessMapDataSet.Tables(0).Rows(i).Item("Note"), String).Trim
						myTableCell = New HtmlTableCell
						myTableCell.Width = NoteWidth
						myTableCell.InnerHtml = myNote
						myTableRow.Cells.Add(myTableCell)

						'process attribute
						myAttributeCodeDataSet = myAttributeCodeDAO.GetEntitys()
						myAttributeCodeDataSet = UtilityObject.QueryPermissionFilter(myAttributeCodeDataSet, AttributeCodeAuthorityTarget, Context.User.Identity.Name)
						myAttributeCodeCount = myAttributeCodeDataSet.Tables(0).Rows.Count

						'only top 10 attribute code will display
						If myAttributeCodeCount > 10 Then
							myAttributeCodeCount = 10
						End If
						If myAttributeCodeCount > 0 Then
							For j = 0 To myAttributeCodeCount - 1
								myAttributeType = CType(myAttributeCodeDataSet.Tables(0).Rows(j).Item("TypeID"), Integer)
								myTableCell = New HtmlTableCell
								myTableCell.Align = "center"
								If myAttributeType = AttributeType.Normal Then
									'normal attribute
									myTableCell.Width = NormalAttributeWidth

									myImage = New HtmlImage
									myAttributeID = CType(myAttributeCodeDataSet.Tables(0).Rows(j).Item("EntityID"), String)

									myAttributeMapDataSet = myAttributeMapDAO.GetEntitysByProcessIDAndAttributeID(myProcessID, myAttributeID)
									myAttributeMapDataSet = UtilityObject.QueryPermissionFilter(myAttributeMapDataSet, AttributeAuthorityTarget, Context.User.Identity.Name)
									myAttributeMapCount = myAttributeMapDataSet.Tables(0).Rows.Count

									If myAttributeMapCount > 0 Then
										myAttributeValue = CType(myAttributeMapDataSet.Tables(0).Rows(0).Item("AttributeValue"), String)
										If myAttributeValue.Trim = "1" Then
