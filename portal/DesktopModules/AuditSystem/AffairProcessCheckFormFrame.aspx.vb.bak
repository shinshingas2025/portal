			'initual control
			LabelResolutionContent.Text = ""
			TextBoxAssociationAffair.Text = ""
			TextBoxAssociationNumber.Text = ""
			TextBoxAssociationDate.Text = ""
			TextBoxAssociationForecastDate.Text = ""
			TextBoxCouncilAffair.Text = ""
			TextBoxCouncilNumber.Text = ""
			TextBoxCouncilDate.Text = ""
			TextBoxCouncilForecastDate.Text = ""
			TextBoxBureauAffair.Text = ""
			TextBoxBureauNumber.Text = ""
			TextBoxBureauDate.Text = ""
			TextBoxBureauForecastDate.Text = ""
			TextBoxSectionAffair.Text = ""
			TextBoxSectionNumber.Text = ""
			TextBoxSectionDate.Text = ""
			TextBoxSectionForecastDate.Text = ""

			ButtonProcessUpdate.Text = "新增"
			ButtonProcessUpdate.Visible = False
			TextBoxProcessDate.Text = ""
			TextBoxProcessDate.Visible = False
			TextBoxProcessState.Text = ""
			TextBoxProcessState.Visible = False
			TextBoxNote.Text = ""
